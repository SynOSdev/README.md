# ~/.gitconfig — Syn_OS Git Defaults
# Merged from hostconfig repo — deduplicated and upgraded

[core]
  editor = nano
  autocrlf = input
  whitespace = fix,-indent-with-non-tab,trailing-space,cr-at-eol
  pager = less -RFX
  excludesFile = ~/.gitignore_global

[init]
  defaultBranch = main

[pull]
  rebase = true

[push]
  default = current
  autoSetupRemote = true

[fetch]
  prune = true
  pruneTags = true

[merge]
  conflictstyle = diff3
  tool = vimdiff

[diff]
  colorMoved = zebra
  algorithm = histogram

[color]
  ui = auto

[alias]
  st = status
  co = checkout
  br = branch
  ci = commit
  lg = log --oneline --graph --decorate --all -20
  last = log -1 HEAD --stat
  unstage = reset HEAD --
  amend = commit --amend --no-edit
  wip = !git add -A && git commit -m 'WIP'
  undo = reset --soft HEAD~1

[credential]
  helper = store

[help]
  autocorrect = 10

[log]
  date = iso
