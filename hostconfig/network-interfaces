# /etc/network/interfaces — Syn_OS Network Interface Configuration
# Merged from hostconfig repo — deduplicated and upgraded

# ---------- Loopback ----------
auto lo
iface lo inet loopback

# ---------- Primary Ethernet ----------
# Auto-configure via DHCP (default for most deployments)
auto eth0
iface eth0 inet dhcp
  # Optional: static configuration
  # address 192.168.1.100
  # netmask 255.255.255.0
  # gateway 192.168.1.1
  # dns-nameservers 1.1.1.1 9.9.9.9

# ---------- USB Tethering (Moto Z Play) ----------
# Brought up automatically when USB tethering is activated on the phone
# The device typically appears as usb0 or rndis0
allow-hotplug usb0
iface usb0 inet dhcp
  # Mobile tethering — auto-configure via DHCP from phone
  # Typical subnet: 192.168.42.0/24

allow-hotplug rndis0
iface rndis0 inet dhcp
  # RNDIS tethering (Windows-style USB networking)

# ---------- Wireless ----------
# Managed via wpa_supplicant or NetworkManager
# allow-hotplug wlan0
# iface wlan0 inet dhcp
#   wpa-conf /etc/wpa_supplicant/wpa_supplicant.conf
